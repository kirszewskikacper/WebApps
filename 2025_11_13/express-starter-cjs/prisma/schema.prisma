// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Wpis{
  id    Int     @id @default(autoincrement())
  title  String
  content String? @db.Text
  Kategoria Kategoria @relation(fields: [id_Kategoria], references: [id])
  id_Kategoria Int
  Komentarz Komentarz[]
}

model Kategoria{
  id    Int     @id @default(autoincrement())
  name  String
  description String? @db.Text
  Wpis Wpis[]
}

model Komentarz{
  id    Int     @id @default(autoincrement())
  name  String?
  content String? @db.Text
  Wpis Wpis @relation(fields: [id_Wpis], references: [id])
  id_Wpis Int
}